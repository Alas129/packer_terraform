aws_region     = "us-west-2"
project_name   = "packer-tf-lab"
amazon_linux_ami_id = "ami-0123456789abcdef0"   # Replace with your Amazon Linux AMI ID or Packer-built AMI
key_name       = "my-key-pair"             # Replace with your AWS key pair name
my_ip_cidr     = "203.0.113.10/32"         # Replace with your public IP (curl ifconfig.me)
ubuntu_instance_count = 3
amazon_linux_instance_count = 3
ansible_controller_instance_type = "t3.micro"
